# Audit Service Database (independent from the main system)
AUDIT_DB_HOST=localhost
AUDIT_DB_PORT=5432
AUDIT_DB_NAME=audit_db
AUDIT_DB_USER=postgres
AUDIT_DB_PASSWORD=postgres

# Redis Streams (read-only: subscribes to system events)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_STREAM=cqrs:events
AUDIT_CONSUMER_GROUP=audit-service
AUDIT_CONSUMER_NAME=auditor-1

# HTTP API
API_PORT=5000

# Reconciliation
RECONCILIATION_INTERVAL_MS=30000
DISCREPANCY_THRESHOLD=0.01

# Circuit Breaker
CB_FAILURE_THRESHOLD=5
CB_SUCCESS_THRESHOLD=3
CB_TIMEOUT_MS=60000

# Alerts
ALERT_WEBHOOK_URL=
